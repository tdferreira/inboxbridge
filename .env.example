# InboxBridge example environment

# Minimum local setup
# These are the only values you need to start the Docker stack, sign in,
# and explore the app locally.
JDBC_URL=jdbc:postgresql://postgres:5432/inboxbridge
JDBC_USERNAME=inboxbridge
JDBC_PASSWORD=inboxbridge
PUBLIC_HOSTNAME=localhost
PUBLIC_PORT=3000
SECURITY_TOKEN_ENCRYPTION_KEY=
SECURITY_TOKEN_ENCRYPTION_KEY_ID=v1
# Optional override when the browser-facing base URL needs a different scheme
# or more complex shape than https://${PUBLIC_HOSTNAME}:${PUBLIC_PORT}.
# PUBLIC_BASE_URL=https://localhost:3000
# Optional override if passkeys should use a different canonical RP ID or
# allowed origins than the derived public hostname/URL above.
# SECURITY_PASSKEY_RP_ID=localhost
# SECURITY_PASSKEY_ORIGINS=https://localhost:3000

# Optional: extra hostnames/IPs to include in the generated self-signed Docker
# certificates. Comma-separated. The generator always keeps the internal Docker
# names plus localhost, and also adds the hostname from PUBLIC_BASE_URL or the
# derived PUBLIC_HOSTNAME / PUBLIC_PORT base URL.
# Examples:
# TLS_FRONTEND_CERT_HOSTNAMES=inboxbridge.local,inboxbridge.your-tailnet.ts.net
# TLS_BACKEND_CERT_HOSTNAMES=inboxbridge.local,inboxbridge.your-tailnet.ts.net
# TLS_FRONTEND_CERT_HOSTNAMES=
# TLS_BACKEND_CERT_HOSTNAMES=

# Optional: backend HTTP/HTTPS listener ports.
# HTTP_PORT=8080
# HTTPS_PORT=8443

# Optional: backend TLS certificate and key mounted into the container.
# In Docker Compose, these files normally come from ./certs/backend.crt and
# ./certs/backend.key on the host.
# If you want to use your own certificate, replace those files before starting
# the stack again. For Let's Encrypt, a common mapping is:
# - fullchain.pem -> ./certs/backend.crt
# - privkey.pem -> ./certs/backend.key
# HTTPS_CERT_FILE=/etc/inboxbridge/certs/backend.crt
# HTTPS_KEY_FILE=/etc/inboxbridge/certs/backend.key

# Optional: shared Google Cloud OAuth app for Gmail API access.
# Register InboxBridge in Google Cloud if you want to use the Gmail API.
# In the normal deployment model, one shared Google Cloud project/client is
# enough for many users. Each user still completes their own Gmail OAuth flow,
# so InboxBridge gets a refresh token for that user's Gmail account.
# These values are deployment-level defaults, not "the admin user's Gmail".
# GOOGLE_CLIENT_ID=replace-me
# GOOGLE_CLIENT_SECRET=replace-me
# Optional deployment-level Gmail refresh token.
# Usually regular users do NOT need this in .env because they connect Gmail from
# the admin UI and their per-user token is stored encrypted in PostgreSQL.
# This is mainly useful for a single-user or fully env-managed deployment.
# GOOGLE_REFRESH_TOKEN=replace-me
# Optional override. Defaults to the derived public base URL plus
# /api/google-oauth/callback.
# GOOGLE_REDIRECT_URI=https://localhost:3000/api/google-oauth/callback

# Optional: shared Microsoft OAuth app registration for Outlook / Hotmail /
# Live sources. Register InboxBridge in Microsoft Entra if you want Outlook /
# Hotmail / Live source accounts to use OAuth2.
# One Entra app can be reused across many user mailboxes; each mailbox still
# grants consent separately. Usually `consumers` for Outlook.com / Hotmail /
# Live, or `common` for mixed personal + work/school.
# MICROSOFT_TENANT=consumers
# MICROSOFT_CLIENT_ID=replace-me
# MICROSOFT_CLIENT_SECRET=replace-me
# Optional override. Defaults to the derived public base URL plus
# /api/microsoft-oauth/callback.
# MICROSOFT_REDIRECT_URI=https://localhost:3000/api/microsoft-oauth/callback

# Optional: passkey / WebAuthn settings.
# Use one canonical hostname if you want passkeys to work from multiple
# networks. One RP ID cannot span unrelated domains such as `.local` and a
# Tailscale `*.ts.net` name at the same time.
# SECURITY_PASSKEYS_ENABLED=true
# SECURITY_PASSKEY_RP_NAME=InboxBridge
# SECURITY_PASSKEY_CHALLENGE_TTL=PT5M

# Optional: login and registration abuse protection.
# Admins can override these live from Administration -> Authentication Security
# without changing .env.
# After this many failed sign-in attempts from the same client IP address,
# InboxBridge blocks new sign-in attempts for the initial block period.
# SECURITY_AUTH_LOGIN_FAILURE_THRESHOLD=5
# Initial lockout applied after the threshold is reached.
# Duration examples: 5m, 30m, 1h, PT5M.
# SECURITY_AUTH_LOGIN_INITIAL_BLOCK=PT5M
# Upper bound for the exponential lockout backoff. Each later block doubles
# until this cap is reached.
# Duration examples: 30m, 1h, 4h, PT1H.
# SECURITY_AUTH_LOGIN_MAX_BLOCK=PT1H
# Enables the anti-robot registration challenge shown in the self-registration
# dialog when MULTI_USER_ENABLED=true.
# SECURITY_AUTH_REGISTRATION_CHALLENGE_ENABLED=true
# Lifetime of each anti-robot challenge before the user must request a new one.
# Duration examples: 5m, 10m, PT10M.
# SECURITY_AUTH_REGISTRATION_CHALLENGE_TTL=PT10M
# Registration CAPTCHA provider. Supported values today: ALTCHA, TURNSTILE,
# HCAPTCHA. ALTCHA is self-hosted, privacy-friendlier, and works without any
# external registration or token, so it is the default.
# SECURITY_AUTH_REGISTRATION_CHALLENGE_PROVIDER=ALTCHA
# ALTCHA proof-of-work tuning. The HMAC key can stay blank in local/dev setups;
# InboxBridge will generate a temporary runtime key. Set a stable secret in
# production so ALTCHA challenges remain valid across restarts.
# SECURITY_AUTH_REGISTRATION_ALTCHA_MAX_NUMBER=100000
# SECURITY_AUTH_REGISTRATION_ALTCHA_HMAC_KEY=
# Optional Cloudflare Turnstile site key and secret. Leave blank to keep this
# provider unavailable in the admin UI.
# SECURITY_AUTH_REGISTRATION_TURNSTILE_SITE_KEY=
# SECURITY_AUTH_REGISTRATION_TURNSTILE_SECRET=
# Optional hCaptcha site key and secret. Leave blank to keep this provider
# unavailable in the admin UI.
# SECURITY_AUTH_REGISTRATION_HCAPTCHA_SITE_KEY=
# SECURITY_AUTH_REGISTRATION_HCAPTCHA_SECRET=
# Enables approximate session-location lookup on new sign-ins only.
# InboxBridge never resolves Geo-IP on every request; it only resolves once
# when a new browser session is created and then reuses the cached result.
# SECURITY_AUTH_GEO_IP_ENABLED=false
# Primary Geo-IP provider. Supported values today: IPWHOIS, IPAPI_CO, IP_API,
# and IPINFO_LITE. IPWHOIS works without a token and is the default primary.
# SECURITY_AUTH_GEO_IP_PRIMARY_PROVIDER=IPWHOIS
# Optional fallback providers tried in order when the primary provider is down
# or rate-limited. Comma-separated values. IPAPI_CO and IP_API work without a
# token; IPINFO_LITE requires SECURITY_AUTH_GEO_IP_IPINFO_TOKEN.
# SECURITY_AUTH_GEO_IP_FALLBACK_PROVIDERS=IPAPI_CO,IP_API,IPINFO_LITE
# Cache lifetime for successful and "not found" Geo-IP lookups.
# Duration examples: 7d, 30d, PT720H.
# SECURITY_AUTH_GEO_IP_CACHE_TTL=PT720H
# Cooldown applied to a provider after retryable failures such as 429 or 5xx.
# While the cooldown is active, InboxBridge skips directly to the next fallback
# provider instead of hammering the failing one.
# Duration examples: 1m, 5m, PT5M.
# SECURITY_AUTH_GEO_IP_PROVIDER_COOLDOWN=PT5M
# Per-request timeout for each Geo-IP provider call.
# Duration examples: 1s, 3s, PT3S.
# SECURITY_AUTH_GEO_IP_REQUEST_TIMEOUT=PT3S
# Optional token for the IPinfo Lite fallback. Leave blank to disable that
# provider. The free IPinfo Lite tier currently returns country-level data.
# SECURITY_AUTH_GEO_IP_IPINFO_TOKEN=

# Optional: environment defaults for the polling engine.
# Admins can override these live from the admin UI without changing .env.
# POLL_ENABLED=true
# POLL_INTERVAL=5m
# FETCH_WINDOW=50
# Minimum spacing between polls against the same source host on one app instance.
# Helps avoid hammering one IMAP/POP server when many accounts share it.
# Duration value. Examples: 1s, 5s, 30s, PT1S. Fractional seconds must use
# ISO-8601, for example PT0.25S for 250 milliseconds.
# SOURCE_HOST_MIN_SPACING=PT1S
# Maximum number of simultaneous polling leases against the same source host.
# Excess work waits for another in-flight lease to finish or expire.
# Plain integer. Examples: 1, 2, 4.
# SOURCE_HOST_MAX_CONCURRENCY=2
# Minimum spacing between delivery operations for the same destination provider
# on one app instance. The default mostly protects Gmail API imports.
# Duration value. Examples: PT0.25S, 1s, 5s, PT1S.
# DESTINATION_PROVIDER_MIN_SPACING=PT0.25S
# Maximum number of simultaneous delivery leases for the same destination
# provider or destination host on one app instance.
# Plain integer. Examples: 1, 2.
# DESTINATION_PROVIDER_MAX_CONCURRENCY=1
# Lease TTL used by the persisted throttle tables so crashed workers do not
# keep a host/provider blocked forever.
# Duration value. Examples: 30s, 2m, 5m, PT2M.
# THROTTLE_LEASE_TTL=PT2M
# Upper bound for the persisted adaptive multiplier that increases spacing when
# contention or provider throttling is detected.
# Plain integer. Examples: 2, 4, 6.
# ADAPTIVE_THROTTLE_MAX_MULTIPLIER=6
# Adds deterministic jitter after each successful poll so many accounts do not
# line up again on the exact same next polling boundary.
# Decimal from 0 to 1. Example: 0.2 means up to 20% of the effective interval.
# SUCCESS_JITTER_RATIO=0.2
# Duration value. Examples: 30s, 2m, PT30S.
# MAX_SUCCESS_JITTER=PT30S

# Optional: deployment mode.
# When false, InboxBridge runs in single-user mode:
# no self-registration, no multi-user admin screens, and no user-management APIs.
# MULTI_USER_ENABLED=true

# Optional: shared Gmail account import target for a deployment-level Gmail token.
# `me` usually means "the Gmail account that granted the OAuth token".
# Most deployments should leave this as `me`.
# GMAIL_DESTINATION_USER=me
# Shared Gmail account import behavior flags.
# GMAIL_CREATE_MISSING_LABELS=true
# GMAIL_NEVER_MARK_SPAM=false
# GMAIL_PROCESS_FOR_CALENDAR=false

# Optional: env-managed source email accounts.
# Add more sources by incrementing the index:
# MAIL_ACCOUNT_1__*, MAIL_ACCOUNT_2__*, etc.
# If no MAIL_ACCOUNT_* values are configured, no env-managed source accounts
# are loaded into the runtime or shown in the admin UI.
# Stable mail fetcher identifier shown in the admin UI and logs.
# MAIL_ACCOUNT_0__ID=outlook-main
# Enables or disables this env-managed source account.
# MAIL_ACCOUNT_0__ENABLED=false
# Mail protocol used to fetch source mail.
# MAIL_ACCOUNT_0__PROTOCOL=IMAP
# Source mailbox host and port.
# MAIL_ACCOUNT_0__HOST=outlook.office365.com
# MAIL_ACCOUNT_0__PORT=993
# TLS requirement for the source connection.
# MAIL_ACCOUNT_0__TLS=true
# PASSWORD for classic username/password or OAUTH2 for provider tokens.
# MAIL_ACCOUNT_0__AUTH_METHOD=PASSWORD
# OAuth provider used when AUTH_METHOD=OAUTH2.
# MAIL_ACCOUNT_0__OAUTH_PROVIDER=NONE
# Source mailbox username or email address.
# MAIL_ACCOUNT_0__USERNAME=replace-me@example.com
# Source mailbox password or app password when AUTH_METHOD=PASSWORD.
# MAIL_ACCOUNT_0__PASSWORD=replace-me-app-password
# Optional manual OAuth refresh token for env-managed OAuth2 sources.
# When secure token storage is enabled, Microsoft OAuth tokens obtained from the
# UI can also be stored encrypted in PostgreSQL instead of living in .env.
# MAIL_ACCOUNT_0__OAUTH_REFRESH_TOKEN=
# IMAP folder name. Ignored for POP3.
# MAIL_ACCOUNT_0__FOLDER=INBOX
# When true, fetch only unread messages from the source.
# MAIL_ACCOUNT_0__UNREAD_ONLY=false
# Gmail label applied after import for this source account.
# MAIL_ACCOUNT_0__CUSTOM_LABEL=Imported/Outlook
