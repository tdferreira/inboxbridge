# PostgreSQL connection used by Quarkus and Flyway.
JDBC_URL=jdbc:postgresql://postgres:5432/inboxbridge
JDBC_USERNAME=inboxbridge
JDBC_PASSWORD=inboxbridge

# Public HTTPS base URL used to derive OAuth callback defaults.
PUBLIC_BASE_URL=https://localhost:3000

# Backend HTTP/HTTPS listener ports.
HTTP_PORT=8080
HTTPS_PORT=8443

# Backend TLS certificate and key mounted into the container.
HTTPS_CERT_FILE=/etc/inboxbridge/certs/backend.crt
HTTPS_KEY_FILE=/etc/inboxbridge/certs/backend.key

# System-wide Gmail destination only.
# Regular users do not edit these values. They only complete Gmail OAuth from the UI.
# Admins may optionally store advanced per-user Gmail overrides in the database.
# Google Cloud OAuth client for the Gmail API.
# In the normal deployment model, one shared Google Cloud project/client is enough for many users.
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
# Gmail refresh token for the shared/system Gmail destination.
GOOGLE_REFRESH_TOKEN=replace-me
# Optional override. Defaults to ${PUBLIC_BASE_URL}/api/google-oauth/callback.
GOOGLE_REDIRECT_URI=https://localhost:3000/api/google-oauth/callback

# Shared Microsoft OAuth app registration for Outlook / Hotmail / Live sources.
# One Entra app can be reused across many user mailboxes; each mailbox still grants consent separately.
# Usually `consumers` for Outlook.com / Hotmail / Live, or `common` for mixed personal + work/school.
MICROSOFT_TENANT=consumers
MICROSOFT_CLIENT_ID=replace-me
MICROSOFT_CLIENT_SECRET=replace-me
# Optional override. Defaults to ${PUBLIC_BASE_URL}/api/microsoft-oauth/callback.
MICROSOFT_REDIRECT_URI=https://localhost:3000/api/microsoft-oauth/callback

# Base64-encoded 32-byte key for encrypting OAuth tokens and user-managed secrets at rest.
BRIDGE_SECURITY_TOKEN_ENCRYPTION_KEY=
# Human-readable key version label stored with encrypted payloads.
BRIDGE_SECURITY_TOKEN_ENCRYPTION_KEY_ID=v1

# Passkey / WebAuthn relying-party settings for admin-ui login.
BRIDGE_SECURITY_PASSKEYS_ENABLED=true
BRIDGE_SECURITY_PASSKEY_RP_ID=localhost
BRIDGE_SECURITY_PASSKEY_RP_NAME=InboxBridge
BRIDGE_SECURITY_PASSKEY_ORIGINS=https://localhost:3000
BRIDGE_SECURITY_PASSKEY_CHALLENGE_TTL=PT5M

# Environment defaults for the polling engine.
# Admins can override these live from the admin UI without changing .env.
BRIDGE_POLL_ENABLED=true
BRIDGE_POLL_INTERVAL=5m
BRIDGE_FETCH_WINDOW=50
# When false, InboxBridge runs in single-user mode:
# no self-registration, no multi-user admin screens, and no user-management APIs.
BRIDGE_MULTI_USER_ENABLED=true
# Gmail API destination user. `me` means "the authenticated Gmail account".
# An explicit Gmail address can also be used when appropriate.
BRIDGE_GMAIL_DESTINATION_USER=me
# Gmail import behavior flags.
BRIDGE_GMAIL_CREATE_MISSING_LABELS=true
BRIDGE_GMAIL_NEVER_MARK_SPAM=false
BRIDGE_GMAIL_PROCESS_FOR_CALENDAR=false

# Source accounts live in .env instead of application.yaml.
# Add more sources by incrementing the index: BRIDGE_SOURCES_1__*, BRIDGE_SOURCES_2__*, etc.
# Stable bridge identifier shown in the admin UI and logs.
BRIDGE_SOURCES_0__ID=outlook-main
# Enables or disables this env-managed source.
BRIDGE_SOURCES_0__ENABLED=false
# Mail protocol used to fetch source mail.
BRIDGE_SOURCES_0__PROTOCOL=IMAP
# Source mailbox host and port.
BRIDGE_SOURCES_0__HOST=outlook.office365.com
BRIDGE_SOURCES_0__PORT=993
# TLS requirement for the source connection.
BRIDGE_SOURCES_0__TLS=true
# PASSWORD for classic username/password or OAUTH2 for provider tokens.
BRIDGE_SOURCES_0__AUTH_METHOD=PASSWORD
# OAuth provider used when AUTH_METHOD=OAUTH2.
BRIDGE_SOURCES_0__OAUTH_PROVIDER=NONE
# Source mailbox username or email address.
BRIDGE_SOURCES_0__USERNAME=replace-me@example.com
# Source mailbox password or app password when AUTH_METHOD=PASSWORD.
BRIDGE_SOURCES_0__PASSWORD=replace-me-app-password
# Optional manual OAuth refresh token for env-managed OAuth2 sources.
BRIDGE_SOURCES_0__OAUTH_REFRESH_TOKEN=
# IMAP folder name. Ignored for POP3.
BRIDGE_SOURCES_0__FOLDER=INBOX
# When true, fetch only unread messages from the source.
BRIDGE_SOURCES_0__UNREAD_ONLY=false
# Gmail label applied after import for this source.
BRIDGE_SOURCES_0__CUSTOM_LABEL=Imported/Outlook
