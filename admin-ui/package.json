{
  "name": "inboxbridge-admin-ui",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "test": "vitest",
    "test:run": "node ./scripts/run-vitest.mjs run --pool forks",
